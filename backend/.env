# ============================================
# 学生教育系统智能体 - 环境配置
# ============================================

# 服务器配置
NODE_ENV=development
PORT=3000
HOST=localhost

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=root
DB_NAME=education_system
DB_CONNECTION_LIMIT=10

# JWT配置
JWT_SECRET=education_system_jwt_secret_key_2026_hailei_chan
JWT_EXPIRES_IN=7d

# 智谱AI配置
ZHIPU_API_KEY=bffcc620687641d1bcfd88b0a38072f8.mzTaQmnUZq4TH2fn
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-4-flash

# Embedding服务配置
EMBEDDING_MODE=api

# Rerank服务配置
RERANK_MODE=local
RERANK_MODEL=rerank
RERANK_TIMEOUT=30000
RERANK_CACHE_ENABLED=true

# 增强版本地Rerank配置
ENHANCED_LOCAL_RERANK=true
LOCAL_RERANK_KEYWORD_WEIGHT=0.25
LOCAL_RERANK_SEMANTIC_WEIGHT=0.65
LOCAL_RERANK_CONTEXT_WEIGHT=0.10

# 文件上传配置
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# 日志配置
LOG_LEVEL=info
LOG_DIR=./logs

# 安全配置
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# CORS配置
CORS_ORIGIN=*

# Coze平台配置
COZE_API_KEY=coze-api-key-2026-hailei-chan-change-this
